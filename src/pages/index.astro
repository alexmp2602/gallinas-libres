---
// Importación de Layout y GSAP para animaciones
import Layout from "../layouts/Layout.astro";
import { onMount } from "solid-js";
import { gsap } from "gsap";

onMount(() => {
  // Animaciones de entrada
  gsap.from(".hero-heading", {
    duration: 1,
    y: -50,
    opacity: 0,
    ease: "power2.out",
  });
  gsap.from(".hero-paragraph", {
    duration: 1,
    y: 50,
    opacity: 0,
    delay: 0.3,
    ease: "power2.out",
  });
  gsap.from(".hero-button", {
    duration: 1,
    scale: 0.8,
    opacity: 0,
    delay: 0.6,
    ease: "elastic.out(1, 0.75)",
  });
  gsap.from(".value-item", {
    duration: 1,
    opacity: 0,
    scale: 0.8,
    stagger: 0.2,
    delay: 1,
    ease: "back.out(1.7)",
  });
});
---

<Layout>
  {/* Hero Section */}
  <section
    class="relative bg-gradient-to-r from-yellow-100 to-green-100 py-12 px-6 mt-12"
  >
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 items-center gap-10"
    >
      <!-- Texto -->
      <div class="text-center md:text-left">
        <h1
          class="hero-heading text-4xl font-extrabold text-gray-900 sm:text-5xl lg:text-6xl"
        >
          Huevos frescos y orgánicos
        </h1>
        <p class="hero-paragraph mt-4 text-lg text-gray-800">
          Disfruta del sabor auténtico y la calidad superior de nuestros huevos
          de gallinas felices y libres.
        </p>
        <div class="mt-6 flex justify-center md:justify-start">
          <a
            href="#productos"
            class="hero-button inline-block bg-yellow-500 text-white px-6 py-3 text-lg font-semibold rounded-md shadow hover:bg-yellow-600 transition-all"
          >
            Ver productos
          </a>
        </div>
      </div>

      <!-- Imagen centrada en su columna -->
      <div class="flex justify-center">
        <img
          src="/img/logo.webp"
          alt="Logo Gallinas Libres"
          class="w-3/4 max-w-md rounded-lg"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section id="nuestra-granja" class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Título General -->
      <div class="text-center mb-8">
        <h1
          class="text-base text-yellow-600 font-semibold tracking-wide uppercase"
        >
          Descubrí lo mejor que tenemos para vos
        </h1>
      </div>

      <!-- Grid principal con 8 columnas -->
      <div class="grid grid-cols-1 lg:grid-cols-8 gap-8">
        <!-- Sección de Producto -->
        <div
          id="productos"
          class="col-span-1 lg:col-span-3 flex flex-col items-center justify-center text-center space-y-4"
        >
          <h2
            class="text-base text-yellow-600 font-semibold tracking-wide uppercase"
          >
            Nuestro producto
          </h2>
          <p
            class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl"
          >
            Huevos frescos y orgánicos
          </p>
          <div class="mt-8">
            <div
              class="bg-white border border-gray-300 shadow-lg rounded-lg p-4 hover:shadow-2xl transition-transform transform"
            >
              <img
                src="/img/webp/maples30.webp"
                alt="Maple de 30 huevos frescos orgánicos en bandeja verde"
                class="rounded-lg mb-3"
                loading="lazy"
              />
              <h3 class="text-lg font-bold text-gray-900">
                Maple de 30 huevos
              </h3>
              <p class="text-gray-600 mt-2">
                Directo del campo, con la frescura y calidad que nos distingue.
              </p>
              <a
                href="https://wa.link/vmk1x2"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition-transform duration-200"
                aria-label="Consultar por WhatsApp sobre Maple de 30 huevos frescos"
              >
                Consultar por WhatsApp
              </a>
            </div>
          </div>
        </div>

        <!-- Línea de separación -->
        <div class="hidden lg:block lg:col-span-1">
          <div class="h-full w-px bg-gray-300 mx-auto"></div>
        </div>

        <!-- Sección de Valores -->
        <div
          id="valores"
          class="col-span-1 lg:col-span-4 flex flex-col items-center justify-center text-center space-y-4"
        >
          <h2
            class="text-base text-yellow-600 font-semibold tracking-wide uppercase"
          >
            Nuestros valores
          </h2>
          <p
            class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl"
          >
            Lo mejor para vos y para las gallinas
          </p>
          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Imagen 1: Gallinas Felices -->
            <div class="flex flex-col items-center space-y-2 p-4">
              <img
                src="/img/webp/gallinas-libres.webp"
                alt="Gallinas felices en espacios abiertos"
                class="rounded-lg shadow w-full h-auto"
                loading="lazy"
              />
              <h3 class="text-md font-bold text-gray-800">Gallinas Felices</h3>
              <p class="text-sm text-gray-600 text-center">
                Nuestras gallinas viven en espacios abiertos y libres.
              </p>
            </div>
            <!-- Imagen 2: Frescura Garantizada -->
            <div class="flex flex-col items-center space-y-2 p-4">
              <img
                src="/img/webp/recoleccion.webp"
                alt="Huevos frescos recolectados diariamente"
                class="rounded-lg shadow w-full h-auto"
                loading="lazy"
              />
              <h3 class="text-md font-bold text-gray-800">
                Frescura Garantizada
              </h3>
              <p class="text-sm text-gray-600 text-center">
                Recolectamos huevos frescos todos los días para vos.
              </p>
            </div>
            <!-- Imagen 3: Sabor Auténtico -->
            <div class="flex flex-col items-center space-y-2 p-4">
              <img
                src="/img/webp/yema.webp"
                alt="Yema de huevo fresco mostrando sabor auténtico"
                class="rounded-lg shadow w-full h-auto"
                loading="lazy"
              />
              <h3 class="text-md font-bold text-gray-800">Sabor Auténtico</h3>
              <p class="text-sm text-gray-600 text-center">
                Nuestros huevos tienen el auténtico sabor del campo.
              </p>
            </div>
            <!-- Imagen 4: 100% Orgánico -->
            <div class="flex flex-col items-center space-y-2 p-4">
              <img
                src="/img/webp/gallinero.webp"
                alt="Gallinero orgánico con granos de alta calidad"
                class="rounded-lg shadow w-full h-auto"
                loading="lazy"
              />
              <h3 class="text-md font-bold text-gray-800">100% Orgánico</h3>
              <p class="text-sm text-gray-600 text-center">
                Gallinas alimentadas con granos orgánicos de alta calidad.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Mapa */}
  <section id="contacto" class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Encabezado -->
      <h2
        class="text-base text-yellow-600 font-semibold tracking-wide uppercase"
      >
        Nuestra ubicación
      </h2>
      <p
        class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl"
      >
        Visítanos en nuestra granja
      </p>
      <p class="text-lg text-gray-600 mt-4">
        Tranquera 1286, Goldney, Argentina
      </p>

      <!-- Contenedor del mapa -->
      <div
        class="mt-8 relative w-full max-w-5xl mx-auto overflow-hidden rounded-xl shadow-lg"
        style="padding-bottom: 56.25%; /* Aspect Ratio 16:9 */"
      >
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d3621.8420983007654!2d-59.274982252615764!3d-34.614530084013715!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzTCsDM2JzUxLjQiUyA1OcKwMTYnMzAuOCJX!5e1!3m2!1ses-419!2sar!4v1734309678815!5m2!1ses-419!2sar"
          class="absolute inset-0 w-full h-full border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa de nuestra granja"></iframe>
      </div>
    </div>
  </section>

  {/* Footer */}
  <footer class="bg-gray-800 text-white py-8">
    <div class="flex flex-col items-center max-w-7xl mx-auto px-4 text-center">
      <img
        src="/img/logo.webp"
        alt="Gallinas Libres Logo"
        class="h-10 w-auto mb-3"
      />
      <p class="text-sm">
        © 2024 Gallinas Libres. Todos los derechos reservados.
      </p>
      <p class="text-sm mt-1">
        Tranquera 1286, Goldney, Argentina | Tel: +54 9 1234567890
      </p>
    </div>
  </footer>
</Layout>
