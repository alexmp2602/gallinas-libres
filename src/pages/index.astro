---
// Importación de Layout y GSAP para animaciones
import Layout from "../layouts/Layout.astro";
import { onMount } from "solid-js";
import { gsap } from "gsap";

onMount(() => {
  // Animaciones de entrada
  gsap.from(".hero-heading", {
    duration: 1,
    y: -50,
    opacity: 0,
    ease: "power2.out",
  });
  gsap.from(".hero-paragraph", {
    duration: 1,
    y: 50,
    opacity: 0,
    delay: 0.3,
    ease: "power2.out",
  });
  gsap.from(".hero-button", {
    duration: 1,
    scale: 0.8,
    opacity: 0,
    delay: 0.6,
    ease: "elastic.out(1, 0.75)",
  });
  gsap.from(".value-item", {
    duration: 1,
    opacity: 0,
    scale: 0.8,
    stagger: 0.2,
    delay: 1,
    ease: "back.out(1.7)",
  });
});
---

<Layout>
  {/* Hero Section */}
  <section
    class="relative bg-gradient-to-r from-yellow-100 to-green-100 py-16 px-8 mt-16"
  >
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 items-center gap-8"
    >
      <!-- Texto -->
      <div class="text-center md:text-left">
        <h1
          class="hero-heading text-4xl font-extrabold text-gray-900 sm:text-5xl lg:text-6xl"
        >
          Huevos frescos y orgánicos
        </h1>
        <p class="hero-paragraph mt-6 text-lg text-gray-800">
          Disfruta del sabor auténtico y la calidad superior de nuestros huevos
          de gallinas felices y libres.
        </p>
        <div class="mt-8 flex justify-center md:justify-start">
          <a
            href="#productos"
            class="hero-button inline-block bg-yellow-500 text-white px-6 py-3 text-lg font-semibold rounded-md shadow hover:bg-yellow-600 transition-all"
          >
            Ver productos
          </a>
        </div>
      </div>

      <!-- Imagen centrada en su columna -->
      <div class="flex justify-center">
        <img
          src="/img/logo.webp"
          alt="Logo Gallinas Libres"
          class="w-3/4 max-w-md rounded-lg"
          loading="lazy"
        />
      </div>
    </div>
  </section>
</Layout>

