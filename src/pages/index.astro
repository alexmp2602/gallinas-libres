        </div>
      </div>

      <!-- Logo y derechos reservados -->
      <div
        class="flex flex-col items-center justify-center flex-grow text-center md:text-left"
      >
        <img
          src="/img/logo.webp"
          alt="Gallinas Libres Logo"
          class="h-24 w-auto"
        />
        <p>© 2024 Gallinas Libres. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>
</Layout>
