---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  {/* Hero Section */}
  <section
    class="relative bg-gradient-to-r from-yellow-100 to-green-100 py-10 px-6 mt-16"
  >
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 items-center gap-10"
    >
      <!-- Texto -->
      <div class="text-center md:text-left">
        <h1
          class="hero-heading text-4xl font-extrabold text-gray-900 sm:text-5xl lg:text-6xl"
        >
          Huevos frescos y orgánicos
        </h1>
        <p class="hero-paragraph mt-4 text-lg text-gray-800">
          Disfruta del sabor auténtico y la calidad superior de nuestros huevos
          de gallinas felices y libres.
        </p>
        <div class="mt-6 flex justify-center md:justify-start">
          <a
            href="#nuestra-granja"
            class="hero-button inline-block bg-yellow-500 text-white px-6 py-3 text-lg font-semibold rounded-md shadow hover:bg-yellow-600 transition-all"
          >
            Ver producto
          </a>
        </div>
      </div>

      <!-- Imagen centrada en su columna -->
      <div class="flex justify-center">
        <img
          src="/img/logo.webp"
          alt="Logo Gallinas Libres"
          class="w-3/4 max-w-md rounded-lg"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  {/* Sección Nuestra Granja */}
  <section id="nuestra-granja" class="py-8 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6">
        <h1
          class="text-base text-yellow-600 font-semibold tracking-wide uppercase"
        >
          Descubrí lo mejor que tenemos para vos
        </h1>
      </div>

      <!-- Grid principal con 8 columnas -->
      <div class="grid grid-cols-1 lg:grid-cols-8 gap-10">
        <!-- Sección de Producto -->
        <div
          id="producto"
          class="col-span-1 lg:col-span-3 flex flex-col items-center text-center"
        >
          <h2
            class="text-base text-yellow-600 font-semibold tracking-wide uppercase"
          >
            Nuestro producto
          </h2>
          <p
            class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl"
          >
            Huevos frescos y orgánicos
          </p>
          <div class="mt-8 mx-4">
            <div
              class="bg-blue-50 border border-gray-300 shadow-lg rounded-lg p-4 hover:shadow-2xl transition-transform transform"
            >
              <img
                src="/img/webp/maples30.webp"
                alt="Maple de 30 huevos frescos orgánicos en bandeja verde"
                class="rounded-lg mb-3"
                loading="lazy"
              />
              <h3 class="text-lg font-bold text-gray-900">
                Maples de 30 huevos
              </h3>
              <p class="text-gray-600 mt-2">
                Directo del campo, con la frescura y calidad que nos distingue.
              </p>
              <a
                href="https://wa.link/vmk1x2"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 mb-2 inline-flex items-center bg-green-500 text-black font-semibold px-4 py-2 rounded-lg hover:bg-green-600 transition-transform duration-200"
                aria-label="Consultar por WhatsApp sobre Maple de 30 huevos frescos"
              >
                <svg
                  fill="#000000"
                  height="24px"
                  width="24px"
                  version="1.1"
                  id="Layer_1"
                  xmlns="http://www.w3.org/2000/svg"
                  xmlns:xlink="http://www.w3.org/1999/xlink"
                  viewBox="0 0 308 308"
                  xml:space="preserve"
                  class="mr-2"
                >
                  <g id="XMLID_468_">
                    <path
                      id="XMLID_469_"
                      d="M227.904,176.981c-0.6-0.288-23.054-11.345-27.044-12.781c-1.629-0.585-3.374-1.156-5.23-1.156
