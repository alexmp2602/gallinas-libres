      </div>

      <!-- Separación -->
      <div class="hidden lg:block lg:col-span-1"></div>

      <!-- Sección de Valores -->
      <div
        id="valores"
        class="col-span-1 lg:col-span-4 text-center lg:text-left"
      >
        <h2
          class="text-base text-yellow-600 font-semibold tracking-wide uppercase"
        >
          Nuestros valores
        </h2>
        <p
