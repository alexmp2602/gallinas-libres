---
import "@/styles/global.css";
import Navbar from "../components/Navbar.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gallinas Libres - Frescura y calidad desde el campo</title>
    <meta
      name="description"
      content="Gallinas Libres ofrece huevos frescos y de calidad, directamente desde nuestras granjas en Goldney."
    />
    <meta
      name="keywords"
      content="huevos frescos, gallinas libres, granja, calidad, Goldney"
    />
    <meta name="author" content="Gallinas Libres" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href="https://www.gallinaslibres.com/" />

    <!-- Open Graph Meta Tags -->
    <meta
      property="og:title"
      content="Gallinas Libres - Frescura y calidad desde el campo"
    />
    <meta
      property="og:description"
      content="Gallinas Libres ofrece huevos frescos y de calidad, directamente desde nuestras granjas en Goldney."
    />
    <meta
      property="og:image"
      content="https://www.gallinaslibres.com/img/logo.webp"
    />
    <meta property="og:url" content="https://www.gallinaslibres.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Gallinas Libres" />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Gallinas Libres - Frescura y calidad desde el campo"
    />
    <meta
      name="twitter:description"
      content="Gallinas Libres ofrece huevos frescos y de calidad, directamente desde nuestras granjas en Goldney."
    />
    <meta
      name="twitter:image"
      content="https://www.gallinaslibres.com/img/logo.webp"
    />
    <meta name="twitter:site" content="@tucuenta" />

    <!-- Fonts and Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Gallinas Libres",
        "url": "https://www.gallinaslibres.com",
        "logo": "/favicon.ico",
        "description": "Gallinas Libres ofrece huevos frescos y de calidad, directamente desde nuestras granjas en Goldney.",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+54 9 2324 56-0122",
          "contactType": "customer service",
          "areaServed": "AR",
          "availableLanguage": ["es", "en"]
        }
      }
    </script>
  </head>
  <body
    class="bg-gray-100 text-gray-800 font-sans antialiased"
    aria-label="Gallinas Libres - Huevos frescos desde Goldney"
  >
    <Navbar />
    <main class="min-h-screen" role="main">
      <slot />
    </main>
  </body>
</html>
