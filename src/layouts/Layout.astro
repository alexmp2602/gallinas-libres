---
import "@/styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gallinas Libres - Frescura y calidad desde el campo</title>
    <meta name="description" content="Gallinas Libres ofrece huevos frescos y de calidad, directamente desde nuestras granjas en Goldney." />
    <meta name="keywords" content="huevos frescos, gallinas libres, granja, calidad, Goldney" />
    <meta name="author" content="Gallinas Libres" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href="https://www.gallinaslibres.com/" />
    <meta property="og:title" content="Gallinas Libres" />
    <meta property="og:description" content="Huevos frescos y de calidad desde Goldney." />
    <meta property="og:image" content="/campo.jpg" />
    <meta property="og:url" content="https://www.gallinaslibres.com" />
    <meta property="og:type" content="website" />
  </head>
  <body class="bg-gray-100 text-gray-800 font-sans antialiased">
    <Navbar />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
  </body>
</html>
